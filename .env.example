# Port the app listens on.
PORT=3000

# Public base URL of this deployment. The API builds player links with it.
APP_BASE_URL=http://localhost:3000

# Optional outbound proxy for MIDI source lookups. Only needed when self-hosting
# on an IP a source blocks, which some do for datacenter ranges. Left unset the
# app talks to sources directly.
# MIDI_SOURCE_PROXY_URL=http://user:password@host:port

# Extra origins whose .mid files a `?url=` link may play, comma separated. The
# app's own origin is always allowed; add a paste service here to open its files
# in the player. Left unset, only files served through this app play.
# NEXT_PUBLIC_MIDI_TRUSTED_ORIGINS=https://s.example.com

# Optional sign in. Leave unset and the app runs anonymously with no login
# button. Set all four to enable accounts and server side score history.
#
# Create a traditional web application in Logto, then point its redirect URI at
# APP_BASE_URL + /callback, which is where this app handles the code exchange.
# The post sign-out redirect and CORS origin are APP_BASE_URL itself.
# LOGTO_ENDPOINT=https://auth.example.com/
# LOGTO_APP_ID=
# LOGTO_APP_SECRET=
#
# This one does not come from Logto. Generate it yourself, at least 32
# characters, and keep it secret: it encrypts the session cookie this app sets.
# LOGTO_COOKIE_SECRET=

# Where scores are kept. A local file by default; point it at libSQL/Turso to
# use a hosted database (then set DATABASE_AUTH_TOKEN too).
DATABASE_URL=file:./data/kinesthesia.db
# DATABASE_AUTH_TOKEN=

# Community links in the footer. Blank either one to hide it.
NEXT_PUBLIC_HOME_LINK=https://h4ks.com
NEXT_PUBLIC_CHAT_LINK=https://chat.h4ks.com

# Optional TURN relay for multiplayer. Without one roughly a fifth of peer
# connections fail behind strict NAT. Cloudflare and Metered both have free tiers.
# NEXT_PUBLIC_TURN_URL=turn:relay.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=
