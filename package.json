{
  "name": "kinesthesia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "hook": "lint-staged",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "ci": "bun run lint && bun run typecheck && bun run test && bun run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@hono/mcp": "0.3.1",
    "@hono/zod-openapi": "1.5.1",
    "@libsql/client": "0.17.4",
    "@logto/next": "^4.2.10",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@scalar/hono-api-reference": "0.11.11",
    "@tonejs/midi": "2.0.28",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30",
    "lucide-react": "^1.25.0",
    "mp4-muxer": "^5.2.2",
    "next": "16.2.10",
    "peerjs": "1.5.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "smplr": "1.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "17.0.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.10"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
