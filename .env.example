# Port the app listens on.
PORT=3000

# Public base URL of this deployment. The API builds player links with it.
APP_BASE_URL=http://localhost:3000

# Optional outbound proxy for MIDI source lookups. Only needed when self-hosting
# on an IP a source blocks, which some do for datacenter ranges. Left unset the
# app talks to sources directly.
# MIDI_SOURCE_PROXY_URL=http://user:password@host:port
