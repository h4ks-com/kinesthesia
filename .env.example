# Port the app listens on.
PORT=3000

# Public base URL of this deployment. The API builds player links with it.
APP_BASE_URL=http://localhost:3000

# Optional outbound proxy for MIDI source lookups. Only needed when self-hosting
# on an IP a source blocks, which some do for datacenter ranges. Left unset the
# app talks to sources directly.
# MIDI_SOURCE_PROXY_URL=http://user:password@host:port

# Optional sign in. Leave unset and the app runs anonymously with no login
# button. Set all four to enable accounts and server side score history.
# LOGTO_ENDPOINT=https://auth.example.com/
# LOGTO_APP_ID=
# LOGTO_APP_SECRET=
# LOGTO_COOKIE_SECRET=

# Where scores are kept when sign in is enabled.
DATABASE_PATH=./data/scores.json
